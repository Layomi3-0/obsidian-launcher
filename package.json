    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "minisearch": "^7.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.20.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
