{
  "name": "quick-launcher",
  "version": "0.1.0",
  "description": "AI-powered system-wide launcher for macOS with Obsidian vault integration",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
